    {
      "id": "chat_text",
      "type": "text",
      "x": 595,
      "y": 655,
      "width": 470,
      "height": 160,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 191,
      "version": 2,
      "versionNonce": 291,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1711000000000,
      "link": null,
      "locked": false,
      "text": "Chat WhatsApp (via Evolution API) — /chat\n\nGET   /chat/chats                     → Listar conversas\nGET   /chat/contacts                  → Listar contatos\nGET   /chat/messages/:remoteJid       → Historico paginado\nPOST  /chat/messages/:remoteJid       → Enviar mensagem manual\n\n→ Envio manual (fromMe=true) pausa o agente por 2h\n→ remoteJid: formato WhatsApp (ex: 5511999999999@s.whatsapp.net)",
      "fontSize": 15,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "middle",
      "containerId": "chat_box",
      "originalText": "Chat WhatsApp (via Evolution API) — /chat\n\nGET   /chat/chats                     → Listar conversas\nGET   /chat/contacts                  → Listar contatos\nGET   /chat/messages/:remoteJid       → Historico paginado\nPOST  /chat/messages/:remoteJid       → Enviar mensagem manual\n\n→ Envio manual (fromMe=true) pausa o agente por 2h\n→ remoteJid: formato WhatsApp (ex: 5511999999999@s.whatsapp.net)",
      "autoResize": true,
      "lineHeight": 1.25
    },

