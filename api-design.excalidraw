      "boundElements": null,
      "updated": 1711000000000,
      "link": null,
      "locked": false,
      "text": "Leads — /leads\n\nPOST   /leads                  → Criar lead\nGET    /leads                  → Listar todos\nGET    /leads/:id              → Detalhe\nPUT    /leads/:id              → Atualizar lead\nDELETE /leads/:id              → Remover lead\n\nRotas aninhadas:\nGET /sellers/:sellerId/leads\n  → Listar leads de um vendedor\nGET /sellers/:sellerId/leads/by-jid/:remoteJid\n  → Buscar lead pelo WhatsApp JID",
      "fontSize": 15,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "middle",
      "containerId": "lead_box",
      "originalText": "Leads — /leads\n\nPOST   /leads                  → Criar lead\nGET    /leads                  → Listar todos\nGET    /leads/:id              → Detalhe\nPUT    /leads/:id              → Atualizar lead\nDELETE /leads/:id              → Remover lead\n\nRotas aninhadas:\nGET /sellers/:sellerId/leads\n  → Listar leads de um vendedor\nGET /sellers/:sellerId/leads/by-jid/:remoteJid\n  → Buscar lead pelo WhatsApp JID",
      "autoResize": true,
      "lineHeight": 1.25
    },

