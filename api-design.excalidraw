    {
      "id": "doc_text",
      "type": "text",
      "x": 595,
      "y": 375,
      "width": 470,
      "height": 240,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 181,
      "version": 2,
      "versionNonce": 281,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1711000000000,
      "link": null,
      "locked": false,
      "text": "Documentos / RAG — Pinecone (base de conhecimento)\n\nDocumentos da Empresa:\n  POST   /companies/:id/documents          → Upload\n  GET    /companies/:id/documents          → Listar\n  DELETE /companies/:id/documents/:docId   → Remover\n\nDocumentos do Vendedor:\n  POST   /sellers/:id/documents            → Upload\n  GET    /sellers/:id/documents            → Listar\n  DELETE /sellers/:id/documents/:docId     → Remover\n\nProcesso: texto → chunking (800 tokens, overlap 200)\n  → embedding (text-embedding-3-small) → Pinecone upsert",
      "fontSize": 15,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "middle",
      "containerId": "doc_box",
      "originalText": "Documentos / RAG — Pinecone (base de conhecimento)\n\nDocumentos da Empresa:\n  POST   /companies/:id/documents          → Upload\n  GET    /companies/:id/documents          → Listar\n  DELETE /companies/:id/documents/:docId   → Remover\n\nDocumentos do Vendedor:\n  POST   /sellers/:id/documents            → Upload\n  GET    /sellers/:id/documents            → Listar\n  DELETE /sellers/:id/documents/:docId     → Remover\n\nProcesso: texto → chunking (800 tokens, overlap 200)\n  → embedding (text-embedding-3-small) → Pinecone upsert",
      "autoResize": true,
      "lineHeight": 1.25
    },

